# Copy to a local .env file before running compose.
# Do not commit the local .env or the secret file it points at.

CSS_BASE_URL=https://databox.example.org/
CSS_PORT=3000
CSS_LOGGING_LEVEL=info
CSS_CONFIG=config/cms/cms-file.json

# This file must contain a randomly generated 32+ byte CMS control token.
# Example generation:
#   openssl rand -base64 48 > ./secrets/cms_control_token.txt
CMS_CONTROL_TOKEN_FILE=./secrets/cms_control_token.txt

# Build the local image yourself, or point at your own private registry image.
CMS_IMAGE=solid-databox:local
