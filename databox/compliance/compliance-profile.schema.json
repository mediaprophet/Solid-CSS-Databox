{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dev.linkeddata.au/schema/solid-databox/compliance-profile/v1",
  "title": "Solid Databox compliance profile",
  "type": "object",
  "required": [ "id", "jurisdiction", "instrumentIds", "reviewStatus", "effectiveFrom" ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "jurisdiction": { "type": "string", "minLength": 2 },
    "instrumentIds": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
    "reviewStatus": { "enum": [ "proposed", "in-review", "attested", "rejected", "superseded" ] },
    "effectiveFrom": { "type": "string", "format": "date-time" },
    "effectiveUntil": { "type": "string", "format": "date-time" },
    "organizationFacts": { "type": "object", "additionalProperties": { "type": [ "boolean", "string", "number", "null" ] } },
    "mappingIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "mappingDigests": { "type": "object", "additionalProperties": { "type": "string", "pattern": "^[a-f0-9]{64}$" } },
    "instrumentDigests": { "type": "object", "additionalProperties": { "type": "string", "pattern": "^[a-f0-9]{64}$" } }
  },
  "additionalProperties": false
}
