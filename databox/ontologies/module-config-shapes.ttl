@prefix ui: <http://www.w3.org/ns/ui#> .
@prefix ipms: <urn:solid-server:databox:ipms#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# ── Hosting module config shape ───────────────────────────────────────

ipms:HostingConfigShape a ui:Form ;
  rdfs:label "Hosting Configuration" ;
  ui:parts (
    [ a ui:TextInput ;
      ui:label "Apex domain" ;
      ui:property schema:domainName ;
      ui:placeholder "acme.org" ;
      ui:required true ;
    ]
    [ a ui:TextInput ;
      ui:label "Databox subdomain" ;
      ui:property ipms:databoxSubdomain ;
      ui:default "databox" ;
    ]
    [ a ui:Boolean ;
      ui:label "Reserve www route" ;
      ui:property ipms:reserveWww ;
      ui:default true ;
    ]
    [ a ui:Choice ;
      ui:label "TLS mode" ;
      ui:property ipms:tlsMode ;
      ui:from ( "cloudflare-proxy" "direct" "tunnel" ) ;
      ui:required true ;
    ]
  ) .

# ── POS module config shape ───────────────────────────────────────────

ipms:PosConfigShape a ui:Form ;
  rdfs:label "POS Configuration" ;
  ui:parts (
    [ a ui:TextInput ;
      ui:label "POS edge binary path" ;
      ui:property ipms:nativeEdgeBinary ;
      ui:placeholder "/usr/local/bin/pos-edge" ;
    ]
    [ a ui:Integer ;
      ui:label "POS edge HTTP port" ;
      ui:property ipms:nativeEdgeHttpPort ;
      ui:default 9100 ;
      ui:min 1024 ;
      ui:max 65535 ;
    ]
    [ a ui:TextInput ;
      ui:label "Thermal printer device" ;
      ui:property ipms:printerDevice ;
      ui:placeholder "/dev/usb/lp0" ;
    ]
    [ a ui:TextInput ;
      ui:label "Customer display device" ;
      ui:property ipms:displayDevice ;
      ui:placeholder "/dev/ttyUSB0" ;
    ]
    [ a ui:Choice ;
      ui:label "Cash drawer connection" ;
      ui:property ipms:cashDrawerVia ;
      ui:from ( "printer" "direct" ) ;
      ui:default "printer" ;
    ]
  ) .

# ── Receipt module config shape ───────────────────────────────────────

ipms:ReceiptConfigShape a ui:Form ;
  rdfs:label "Receipt Configuration" ;
  ui:parts (
    [ a ui:TextInput ;
      ui:label "Receipt footer text" ;
      ui:property ipms:receiptFooter ;
      ui:placeholder "Thank you for your purchase!" ;
    ]
    [ a ui:Boolean ;
      ui:label "Print QR code on receipt" ;
      ui:property ipms:printQrOnReceipt ;
      ui:default true ;
    ]
    [ a ui:Integer ;
      ui:label "QR code scale (pixels per module)" ;
      ui:property ipms:qrScale ;
      ui:default 8 ;
      ui:min 1 ;
      ui:max 32 ;
    ]
  ) .
