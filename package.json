{
  "name": "@solid/community-server",
  "version": "1.2.0",
  "description": "Solid Databox: an organisation-hosted, governed Solid data exchange, built on the Community Solid Server.",
  "license": "MIT",
  "homepage": "https://github.com/mediaprophet/Solid-CSS-Databox#readme",
  "repository": "git@github.com:mediaprophet/Solid-CSS-Databox.git",
  "bugs": {
    "url": "https://github.com/mediaprophet/Solid-CSS-Databox/issues"
  },
  "keywords": [
    "solid",
    "linked-data",
    "rdf",
    "ldp",
    "databox",
    "data-exchange",
    "consent",
    "data-portability"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "community-solid-server": "bin/server.js"
  },
  "files": [
    "bin",
    "config",
    "dist",
    "patches",
    "templates"
  ],
  "engines": {
    "node": ">=24.0"
  },
  "lsd:module": "https://linkedsoftwaredependencies.org/bundles/npm/@solid/community-server",
  "lsd:components": "dist/components/components.jsonld",
  "lsd:contexts": {
    "https://linkedsoftwaredependencies.org/bundles/npm/@solid/community-server/^1.0.0/components/context.jsonld": "dist/components/context.jsonld"
  },
  "lsd:importPaths": {
    "https://linkedsoftwaredependencies.org/bundles/npm/@solid/community-server/^1.0.0/components/": "dist/components/",
    "https://linkedsoftwaredependencies.org/bundles/npm/@solid/community-server/^1.0.0/config/": "config/",
    "https://linkedsoftwaredependencies.org/bundles/npm/@solid/community-server/^1.0.0/dist/": "dist/",
    "https://linkedsoftwaredependencies.org/bundles/npm/@solid/community-server/^1.0.0/templates/config/": "templates/config/"
  },
  "scripts": {
    "build": "npm run build:ts && npm run build:components",
    "build:components": "componentsjs-generator -s src -c dist/components -r css -i .componentsignore",
    "build:ts": "tsc",
    "check:version": "node scripts/check-version-consistency.mjs",
    "build:demo": "node scripts/build-databox-demo.mjs",
    "mkdocs": "npm run mkdocs:docker || npm run mkdocs:pip",
    "mkdocs:docker": "docker run --rm -it -p 8000:8000 -v ${PWD}/documentation:/docs squidfunk/mkdocs-material",
    "mkdocs:pip": "pip install mkdocs mkdocs-material && cd documentation && mkdocs serve",
    "docker": "npm run docker:setup && npm run docker:start",
    "docker:clean": "./test/docker/docker-clean.sh",
    "docker:setup": "./test/docker/docker-setup.sh",
    "docker:start": "./test/docker/docker-start.sh",
    "docker:stop": "./test/docker/docker-stop.sh",
    "demo:databox-forge": "ts-node ./scripts/databoxMappingForgeDemo.ts",
    "demo:seraphim-forge": "ts-node ./scripts/seraphimForgeDemo.ts",
    "start:databox-live": "node ./bin/server.js -c config/databox/live.json",
    "start:databox-demo": "node ./bin/server.js -c config/databox/live.json --databoxControlToken 12345678901234567890123456789012",
    "start:ipms": "node ./bin/server.js -c config/ipms/ipms.json",
    "start:ipms-demo": "node ./bin/server.js -c config/ipms/ipms.json --ipmsControlToken 12345678901234567890123456789012",
    "start:pos": "node ./bin/server.js -c config/ipms/pos.json",
    "start:pos-demo": "node ./bin/server.js -c config/ipms/pos.json --ipmsControlToken 12345678901234567890123456789012",
    "build:native": "cargo build --release --manifest-path native/Cargo.toml",
    "build:pos-edge": "cargo build --release --manifest-path native/pos-edge/Cargo.toml",
    "build:tray": "cargo build --release --manifest-path native/tray-supervisor/Cargo.toml",
    "build:installer": "cargo build --release --manifest-path native/installer/Cargo.toml",
    "package:desktop": "npm run build && npm run build:native && node scripts/package-desktop.mjs",
    "install:server": "cargo run --release --manifest-path native/installer/Cargo.toml -- --package-type ipms:ServerInstall",
    "install:pos": "cargo run --release --manifest-path native/installer/Cargo.toml -- --package-type ipms:PosInstall",
    "install:combined": "cargo run --release --manifest-path native/installer/Cargo.toml -- --package-type ipms:CombinedInstall",
    "test:ipms:oxigraph": "node ./scripts/run-ipms-oxigraph-smoke.mjs",
    "test:ipms:deployment": "node ./scripts/validate-ipms-deployment.mjs",
    "test:ipms:oxigraph:optional": "node ./scripts/run-ipms-oxigraph-smoke.mjs --skip-when-unavailable",
    "test:ipms:oxigraph:split": "node ./scripts/run-ipms-oxigraph-smoke.mjs --mode=split",
    "test:ipms:oxigraph:unified": "node ./scripts/run-ipms-oxigraph-smoke.mjs --mode=unified",
    "typedocs": "typedoc --customCss ./documentation/typedoc.css",
    "jest": "jest --coverageReporters text-summary --",
    "lint": "npm run check:version && npm run lint:eslint && npm run lint:markdown",
    "lint:eslint": "node ./scripts/run-eslint.mjs",
    "lint:markdown": "markdownlint-cli2",
    "prepare": "husky",
    "postinstall": "patch-package",
    "release": "commit-and-tag-version",
    "postrelease": "ts-node ./scripts/finalizeRelease.ts",
    "start": "node ./bin/server.js",
    "start:file": "node ./bin/server.js -c config/file.json -f ./.data",
    "start:file-root": "node ./bin/server.js -c config/file-root.json -f ./.data",
    "test": "npm run test:ts && npm run jest",
    "test:deploy": "test/deploy/validate-configs.sh",
    "test:ts": "tsc -p test --noEmit",
    "test:integration": "jest test/integration",
    "test:unit": "jest --config=./jest.coverage.config.js test/unit",
    "test:watch": "jest --coverageReporters none --watch test/unit",
    "validate": "componentsjs-compile-config urn:solid-server:default:Initializer -c config/default.json -f > /dev/null",
    "watch": "nodemon --watch \"dist/**/*.js\" --exec npm start"
  },
  "dependencies": {
    "@comunica/context-entries": "^5.3.0",
    "@comunica/query-sparql": "^5.3.0",
    "@isaacs/ttlcache": "^2.1.5",
    "@rdfjs/types": "^2.0.1",
    "@solid/access-control-policy": "^1.0.0",
    "@solid/access-token-verifier": "^2.1.1",
    "@types/async-lock": "^1.4.2",
    "@types/cors": "^2.8.19",
    "@types/ejs": "^3.1.5",
    "@types/end-of-stream": "^1.4.4",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash.orderby": "^4.6.9",
    "@types/mime-types": "^3.0.1",
    "@types/n3": "^1.26.1",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/oidc-provider": "^8.8.1",
    "@types/proper-lockfile": "^4.1.4",
    "@types/pump": "^1.1.3",
    "@types/punycode": "^2.1.4",
    "@types/sparqljs": "^3.1.12",
    "@types/ws": "^8.18.1",
    "@types/yargs": "^17.0.35",
    "arrayify-stream": "^3.0.0",
    "async-lock": "^1.4.1",
    "bcryptjs": "^3.0.3",
    "componentsjs": "^6.4.0",
    "cookie": "^2.0.1",
    "cors": "^2.8.6",
    "cross-fetch": "^4.1.0",
    "ejs": "^6.0.1",
    "end-of-stream": "^1.4.5",
    "escape-string-regexp": "^5.0.0",
    "eslint": "^10.7.0",
    "fetch-sparql-endpoint": "^7.1.1",
    "fs-extra": "^11.3.6",
    "handlebars": "^4.7.9",
    "ioredis": "^5.11.1",
    "iso8601-duration": "^2.1.4",
    "jose": "^6.2.3",
    "jsonld-context-parser": "^3.1.0",
    "lodash.orderby": "^4.18.0",
    "marked": "^18.0.7",
    "mime-types": "^3.0.2",
    "n3": "^2.1.1",
    "nodemailer": "^9.0.3",
    "oidc-provider": "^8.8.1",
    "proper-lockfile": "^4.1.2",
    "pump": "^3.0.4",
    "punycode": "^2.3.1",
    "rdf-dereference": "^5.0.0",
    "rdf-parse": "^5.0.0",
    "rdf-serialize": "^5.1.0",
    "rdf-string": "^2.0.1",
    "rdf-terms": "^2.0.0",
    "rdf-validate-shacl": "^0.6.5",
    "sparqlalgebrajs": "^5.0.2",
    "sparqljs": "^3.7.4",
    "url-join": "^5.0.0",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0",
    "ws": "^8.21.1",
    "yargs": "^17.7.2",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@inrupt/solid-client-authn-core": "^5.0.0",
    "@inrupt/solid-client-authn-node": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/set-cookie-parser": "^2.4.10",
    "@types/supertest": "^7.2.1",
    "commit-and-tag-version": "^13.1.0",
    "componentsjs-generator": "^4.3.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-esm-transformer-2": "^1.0.0",
    "jest-rdf": "^2.0.0",
    "markdownlint-cli2": "^0.23.1",
    "node-mocks-http": "^1.18.1",
    "nodemon": "^3.1.14",
    "opinionated-eslint-config": "0.2.0",
    "oxigraph": "^0.5.9",
    "patch-package": "^8.0.1",
    "set-cookie-parser": "^3.1.2",
    "simple-git": "^3.36.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.20",
    "typescript": "~6.0.2"
  },
  "commit-and-tag-version": {
    "scripts": {
      "postbump": "ts-node ./scripts/upgradeConfig.ts",
      "postchangelog": "ts-node ./scripts/formatChangelog.ts && markdownlint-cli2 --fix"
    },
    "writerOpts": {
      "commitsSort": false
    },
    "skip": {
      "tag": true
    }
  }
}
